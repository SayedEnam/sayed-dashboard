{
  "name": "sayed/sayed-dashboard",
  "description": "A complete admin dashboard package for Laravel applications",
  "type": "laravel-package",
  "license": "MIT",
  "authors": [
    {
      "name": "Md.Syed Enam",
      "email": "syedenamshohag@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Sayed\\SayedDashboard\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sayed\\SayedDashboard\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sayed\\SayedDashboard\\SayedDashboardServiceProvider"
      ],
      "aliases": {
        "SayedDashboard": "Sayed\\SayedDashboard\\Facades\\SayedDashboard"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
